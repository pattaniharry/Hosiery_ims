generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model brands {
  id         Int        @id @default(autoincrement())
  name       String     @unique @db.VarChar(100)
  created_at DateTime?  @default(now()) @db.Timestamp(6)
  products   products[]
}

model categories {
  id         Int        @id @default(autoincrement())
  name       String     @unique @db.VarChar(100)
  created_at DateTime?  @default(now()) @db.Timestamp(6)
  products   products[]
}

model colours {
  id         Int                @id @default(autoincrement())
  name       String             @unique @db.VarChar(100)
  created_at DateTime?          @default(now()) @db.Timestamp(6)
  variants   product_variants[]
}

model csv_import_logs {
  id                 Int       @id @default(autoincrement())
  file_name          String?   @db.VarChar(255)
  imported_by        String?
  total_records      Int?
  successful_records Int?
  failed_records     Int?
  created_at         DateTime? @default(now()) @db.Timestamp(6)
  users              users?    @relation(fields: [imported_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model inventory {
  id         Int              @id @default(autoincrement())
  variant_id Int              @unique
  quantity   Int              @default(0)
  updated_at DateTime         @updatedAt
  variant    product_variants @relation(fields: [variant_id], references: [id])
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model inventory_transactions {
  id           Int              @id @default(autoincrement())
  variant_id   Int
  txn_type     String?          @db.VarChar(20)
  quantity     Int
  remarks      String?
  performed_by String?
  created_at   DateTime?        @default(now()) @db.Timestamp(6)
  users        users?           @relation(fields: [performed_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  variant      product_variants @relation(fields: [variant_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model products {
  id                  Int                @id @default(autoincrement())
  sku                 String             @unique @db.VarChar(100)
  product_name        String             @db.VarChar(255)
  brand_id            Int?
  category_id         Int?
  supplier_id         Int?
  product_description String?
  min_stock           Int?               @default(0)
  created_at          DateTime?          @default(now()) @db.Timestamp(6)
  updated_at          DateTime           @updatedAt
  variants            product_variants[]
  brands              brands?            @relation(fields: [brand_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  categories          categories?        @relation(fields: [category_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  suppliers           suppliers?         @relation(fields: [supplier_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model product_variants {
  id                     Int                      @id @default(autoincrement())
  product_id             Int
  sku                    String                   @unique @db.VarChar(100)
  size_id                Int?
  color_id               Int?
  purchase_price         Decimal?                 @db.Decimal(10, 2)
  selling_price          Decimal?                 @db.Decimal(10, 2)
  created_at             DateTime?                @default(now()) @db.Timestamp(6)
  updated_at             DateTime                 @updatedAt
  inventory              inventory?
  inventory_transactions inventory_transactions[]
  colour                 colours?                 @relation(fields: [color_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  product                products                 @relation(fields: [product_id], references: [id], onDelete: Cascade)
  size                   sizes?                   @relation(fields: [size_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  stock_adjustments      stock_adjustments[]

  @@unique([product_id, color_id, size_id])
}

model roles {
  id    Int     @id @default(autoincrement())
  name  String  @unique @db.VarChar(50)
  users users[]
}

model sizes {
  id         Int                @id @default(autoincrement())
  name       String             @unique @db.VarChar(100)
  created_at DateTime?          @default(now()) @db.Timestamp(6)
  variants   product_variants[]
}

model stock_adjustments {
  id           Int              @id @default(autoincrement())
  variant_id   Int
  old_quantity Int?
  new_quantity Int?
  reason       String?
  adjusted_by  String?
  created_at   DateTime?        @default(now()) @db.Timestamp(6)
  users        users?           @relation(fields: [adjusted_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  variant      product_variants @relation(fields: [variant_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model suppliers {
  id       Int        @id @default(autoincrement())
  name     String     @unique @db.VarChar(255)
  phone    String?    @db.VarChar(30)
  address  String?
  products products[]
}

model users {
  id                     String                   @id @default(cuid())
  clerk_id               String                   @unique
  full_name              String                   @db.VarChar(255)
  email                  String                   @unique @db.VarChar(255)
  role_id                Int?
  is_active              Boolean?                 @default(true)
  created_at             DateTime?                @default(now()) @db.Timestamp(6)
  updated_at             DateTime                 @updatedAt
  csv_import_logs        csv_import_logs[]
  inventory_transactions inventory_transactions[]
  stock_adjustments      stock_adjustments[]
  roles                  roles?                   @relation(fields: [role_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}
